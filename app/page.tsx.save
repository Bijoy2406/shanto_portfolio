        />
      </section>

      <div className="bg-background w-full">
        <div className="max-w-[1200px] mx-auto px-8 pt-8 pb-12">
          {/* CAD Projects */}
          <h3 className="text-2xl font-bold text-center mb-10 text-on-surface animate-fade-in-up">CAD Projects</h3>
